# Anthropic API key for AI-generated narratives (required)
ANTHROPIC_API_KEY=your-api-key-here

# AI narrative feature toggle (default: true)
NARRATIVE_ENABLED=true

# Claude model for narrative generation (default: claude-opus-4-6)
NARRATIVE_MODEL=claude-opus-4-6

# Optional: override default data file for local development
DATA_FILE=motor_main_data.csv

# Home insurance Power BI fabric instance (defaults shown)
# IMPORTANT: The workspace ID is the Fabric "group" ID from the URL:
#   app.fabric.microsoft.com/groups/<WORKSPACE_ID>/...
# The DATASET_ID must be the *semantic model* ID, NOT the dataflow ID.
# Dataflows (e.g. e6f052b4-...) ingest/transform data; semantic models
# expose it for DAX queries. To find the correct dataset ID:
#   1. Open the Fabric workspace (groups/1c6e2798-...).
#   2. Find the semantic model that contains the home insurance survey data.
#   3. Copy the dataset ID from the URL or query:
#      GET https://api.powerbi.com/v1.0/myorg/groups/{workspace_id}/datasets
HOME_WORKSPACE_ID=1c6e2798-9b81-4643-82a2-791780138db3
HOME_DATASET_ID=71b28688-1e7e-421b-bb28-ccd29518ad94
