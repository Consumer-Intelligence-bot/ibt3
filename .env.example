# -----------------------------------------------------------------------
# Consumer Intelligence IBT Portal — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# -----------------------------------------------------------------------

# ---- Azure / Power BI (required) --------------------------------------
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here

# ---- Motor Power BI instance (required) -------------------------------
MOTOR_WORKSPACE_ID=your-motor-workspace-id-here
MOTOR_DATASET_ID=your-motor-dataset-id-here

# ---- Home Power BI instance (required) --------------------------------
HOME_WORKSPACE_ID=your-home-workspace-id-here
HOME_DATASET_ID=your-home-dataset-id-here

# ---- Anthropic API (required for AI narratives) -----------------------
ANTHROPIC_API_KEY=your-api-key-here

# ---- Feature toggles (optional, defaults shown) -----------------------
NARRATIVE_ENABLED=true
NARRATIVE_MODEL=claude-opus-4-6

# ---- DuckDB cache path (optional, default shown) ----------------------
# IBT3_DB_PATH=/home/user/.ibt3/cache.duckdb
